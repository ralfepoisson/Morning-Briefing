@startuml
hide circle
hide methods
skinparam classAttributeIconSize 0
skinparam linetype ortho
left to right direction

class Tenant {
  +tenant_id : UUID
  --
  tenant_name : varchar
  tenant_slug : varchar
  status : varchar
  created_at : timestamp
  updated_at : timestamp
}

class AppUser {
  +user_id : UUID
  --
  tenant_id : UUID
  email : varchar
  display_name : varchar
  timezone : varchar
  locale : varchar
  is_active : boolean
  created_at : timestamp
  updated_at : timestamp
}

class Dashboard {
  +dashboard_id : UUID
  --
  tenant_id : UUID
  owner_user_id : UUID
  name : varchar
  description : varchar
  dashboard_type : varchar
  is_default : boolean
  is_active : boolean
  is_generating : boolean
  version : int
  activation_rule_json : json
  theme_json : json
  created_at : timestamp
  updated_at : timestamp
}

class DashboardWidget {
  +dashboard_widget_id : UUID
  --
  tenant_id : UUID
  dashboard_id : UUID
  widget_type : varchar
  title : varchar
  position_x : int
  position_y : int
  width : int
  height : int
  min_width : int
  min_height : int
  is_visible : boolean
  is_generating : boolean
  refresh_mode : varchar
  sort_order : int
  version : int
  config_json : json
  config_hash : varchar
  include_in_briefing_override : boolean?
  created_at : timestamp
  updated_at : timestamp
}

class Connector {
  +connector_id : UUID
  --
  tenant_id : UUID
  connector_type : varchar
  name : varchar
  status : varchar
  auth_type : varchar
  base_url : varchar
  config_json : json
  secret_ref : varchar
  last_sync_at : timestamp
  created_at : timestamp
  updated_at : timestamp
}

class WidgetConnector {
  +widget_connector_id : UUID
  --
  dashboard_widget_id : UUID
  connector_id : UUID
  usage_role : varchar
  created_at : timestamp
}

class BriefingSnapshot {
  +snapshot_id : UUID
  --
  tenant_id : UUID
  user_id : UUID
  dashboard_id : UUID
  snapshot_date : date
  generated_at : timestamp
  generation_status : varchar
  summary_json : json
  expires_at : timestamp
}

class WidgetSnapshot {
  +widget_snapshot_id : UUID
  --
  snapshot_id : UUID
  dashboard_widget_id : UUID
  widget_type : varchar
  title : varchar
  content_json : json
  content_hash : varchar
  generated_at : timestamp
  status : varchar
  error_message : varchar
}

class SnapshotGenerationJob {
  +snapshot_generation_job_id : UUID
  --
  widget_id : UUID
  dashboard_id : UUID
  tenant_id : UUID
  user_id : UUID
  snapshot_date : date
  trigger_source : varchar
  idempotency_key : varchar
  requested_config_version : int
  requested_config_hash : varchar
  status : varchar
  attempt_count : int
  last_message_id : varchar
  last_error : varchar
  started_at : timestamp
  completed_at : timestamp
  created_at : timestamp
  updated_at : timestamp
}

class DashboardBriefingPreference {
  +dashboard_briefing_preference_id : UUID
  --
  dashboard_id : UUID
  enabled : boolean
  auto_generate : boolean
  target_duration_seconds : int
  tone : varchar
  language : varchar
  voice_name : varchar
  include_widget_types_json : json
  created_at : timestamp
  updated_at : timestamp
}

class TenantAiConfiguration {
  +tenant_ai_configuration_id : UUID
  --
  tenant_id : UUID
  openai_api_key : varchar
  openai_model : varchar
  created_at : timestamp
  updated_at : timestamp
}

class DashboardBriefing {
  +dashboard_briefing_id : UUID
  --
  dashboard_id : UUID
  status : varchar
  source_snapshot_hash : varchar
  generated_at : timestamp
  model_name : varchar
  prompt_version : varchar
  script_text : text
  script_json : json
  estimated_duration_seconds : int
  error_message : varchar
  created_at : timestamp
  updated_at : timestamp
}

class DashboardBriefingAudio {
  +dashboard_briefing_audio_id : UUID
  --
  dashboard_briefing_id : UUID
  provider : varchar
  voice_name : varchar
  storage_key : varchar
  mime_type : varchar
  duration_seconds : int
  generated_at : timestamp
  created_at : timestamp
  updated_at : timestamp
}

Tenant "1" -- "0..*" AppUser : has >
Tenant "1" -- "0..*" Dashboard : owns >
Tenant "1" -- "0..*" Connector : provides >
Tenant "1" -- "0..*" DashboardWidget : scopes >
Tenant "1" -- "0..*" BriefingSnapshot : contains >
Tenant "1" -- "0..1" TenantAiConfiguration : configures >

AppUser "1" -- "0..*" Dashboard : owns >
Dashboard "1" -- "0..*" DashboardWidget : contains >

DashboardWidget "1" -- "0..*" WidgetConnector : uses >
Connector "1" -- "0..*" WidgetConnector : linked to >

AppUser "1" -- "0..*" BriefingSnapshot : receives >
Dashboard "1" -- "0..*" BriefingSnapshot : rendered as >

BriefingSnapshot "1" -- "0..*" WidgetSnapshot : includes >
DashboardWidget "1" -- "0..*" WidgetSnapshot : materialised as >
DashboardWidget "1" -- "0..*" SnapshotGenerationJob : requested as >
AppUser "1" -- "0..*" SnapshotGenerationJob : requested for >
Dashboard "1" -- "0..*" SnapshotGenerationJob : scoped to >
Dashboard "1" -- "0..1" DashboardBriefingPreference : configures >
Dashboard "1" -- "0..*" DashboardBriefing : produces >
DashboardBriefing "1" -- "0..*" DashboardBriefingAudio : renders >

note right of DashboardWidget
Represents the configured widget instance
placed on a dashboard layout.
end note

note right of WidgetSnapshot
Stores the resolved content displayed
for a widget at a specific point in time.
Denormalises widget type and title so
historical snapshots remain readable even
if widget configuration changes later.
end note

note right of SnapshotGenerationJob
Tracks idempotent widget snapshot commands.
Used to coalesce duplicate SQS deliveries,
record retries, and mark stale jobs skipped.
The logical key is widget_id + snapshot_date
+ requested_config_hash.
end note

note bottom of Connector
Tenant-level integration configuration,
for example weather, calendar, email, RSS, or news.
Secrets stay outside Postgres and are
referenced through secret_ref.
end note

note bottom of BriefingSnapshot
Recommended unique key:
(user_id, dashboard_id, snapshot_date)
end note

note right of DashboardBriefing
Dashboard-level derived artifact built
from the latest eligible widget snapshots.
Stores the structured script contract and
the source hash used for cache reuse.
end note

note right of DashboardBriefingPreference
Controls whether dashboard audio briefing
is enabled and how it should sound.
Widget instance overrides still control
which widgets contribute content.
end note

note right of TenantAiConfiguration
Stores the tenant-scoped OpenAI API key
and selected model used by shared
AI summarization and briefing generation.
end note

@enduml
