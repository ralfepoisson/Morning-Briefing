{
  "name": "morning-briefing-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend and database tooling for Morning Briefing",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "start": "tsx src/app/server.ts",
    "db:create": "tsx scripts/create-database.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:init": "npm run db:create && npm run db:migrate -- --name init && npm run db:seed",
    "db:reset": "prisma migrate reset --force",
    "reference:import:cities": "tsx scripts/import-reference-cities.ts",
    "snapshot:queues:setup": "tsx scripts/setup-snapshot-queues.ts",
    "snapshot:worker": "tsx scripts/run-snapshot-worker.ts",
    "snapshot:refresh:nightly": "tsx scripts/run-nightly-refresh.ts",
    "prisma:studio": "prisma studio",
    "test": "node --test --import tsx",
    "watch": "watch 'npm run build' ./"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1012.0",
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.6.0",
    "adm-zip": "^0.5.16",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^6.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
